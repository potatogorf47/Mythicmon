<!DOCTYPE html>
<html>
<head>
    <title>MythicMon</title>
    <link rel="stylesheet" href="style.css">
    <script src="script.js"></script>
</head>
<body>
  <nav>

    <div class="logo">
        MythicMon
    </div>

    <div class="nav-links">
        <a href="#">Shop</a>
        <a href="#">Cards</a>
        <a href="#">Safari</a>
        <a href="#">Collection</a>
        <a href="#">Arena</a>
    </div>

    <div class="currency">

        Coins:
        <span id="coin-display">
        100
        </span>

    </div>

</nav>

<section class="hero">

    <h1>
        Pack Shop
    </h1>

    <p>
        Open packs, collect creatures,
        and build your collection.
    </p>

    <section class="pack-section">

        <h2>Type Packs</h2>

        <div class="pack-grid">

            <!-- WATER PACK -->
            <div class="pack-card water">

                <h3>Aqua Surge</h3>

                <p>Water Type Pack</p>

                <button onclick="openPack()">
                    Open Pack
                </button>

            </div>

            <!-- FIRE PACK -->
            <div class="pack-card fire">

                <h3>Inferno Blaze</h3>

                <p>Fire Type Pack</p>

                <button onclick="openPack()">
                    Open Pack
                </button>

            </div>

            <!-- NATURE PACK -->
            <div class="pack-card nature">

                <h3>Jungle Bloom</h3>

                <p>Nature Type Pack</p>

                <button onclick="openPack()">
                    Open Pack
                </button>
            </div>

        </div>

    </section>

<section id="starter-selection">

    <h2>
        Choose Your Starter
    </h2>

    <button onclick="chooseStarter('Flaretail')">
        Flaretail
    </button>

    <button onclick="chooseStarter('Aquafang')">
        Aquafang
    </button>

    <button onclick="chooseStarter('Leafhorn')">
        Leafhorn
    </button>

</section>

<section id="safari">

    <h2>
        Safari Zone
    </h2>

    <button>
        Enter Meadow Safari
    </button>

    <button>
        Enter Mountain Safari
    </button>

    <button>
        Enter Cosmic Safari
    </button>

</section>

<section id="game-output">

    <h2>
        Game Events
    </h2>

    <div id="output">

    </div>

</section>

<section id="collection">

    <h2>
        Collection
    </h2>

    <div id="collection-list">

    </div>

</section>

<script src="script.js">

</body>
</html>
